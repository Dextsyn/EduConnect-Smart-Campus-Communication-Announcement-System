@model EduConnect.Web.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var roleName = Context.Session.GetString("RoleName");
    var userName = Context.Session.GetString("UserName");
}

<!-- ─── STAT CARDS ─────────────────────── -->
<div class="row g-3 mb-4">

    <!-- Total Announcements -->
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle p-3 bg-primary bg-opacity-10">
                    <i class="bi bi-megaphone text-primary fs-4"></i>
                </div>
                <div>
                    <div class="fw-bold fs-4">
                        @Model.TotalAnnouncements
                    </div>
                    <div class="text-muted small">
                        Total Announcements
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Today's Announcements -->
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle p-3 bg-success bg-opacity-10">
                    <i class="bi bi-calendar-check text-success fs-4"></i>
                </div>
                <div>
                    <div class="fw-bold fs-4">
                        @Model.TodayAnnouncements
                    </div>
                    <div class="text-muted small">
                        Posted Today
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Unread Notifications -->
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle p-3 bg-warning bg-opacity-10">
                    <i class="bi bi-bell text-warning fs-4"></i>
                </div>
                <div>
                    <div class="fw-bold fs-4">
                        @Model.UnreadNotifications
                    </div>
                    <div class="text-muted small">
                        Unread Notifications
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Role Specific Card -->
    @if (roleName == "Administrator")
    {
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle p-3 bg-info bg-opacity-10">
                        <i class="bi bi-people text-info fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4">
                            @Model.TotalUsers
                        </div>
                        <div class="text-muted small">
                            Active Users
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (roleName == "Faculty" || roleName == "Staff")
    {
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle p-3 bg-info bg-opacity-10">
                        <i class="bi bi-eye text-info fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4">
                            @Model.TotalViews
                        </div>
                        <div class="text-muted small">
                            Total Views
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle p-3 bg-info bg-opacity-10">
                        <i class="bi bi-calendar-event text-info fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-4">
                            @Model.UpcomingEvents
                        </div>
                        <div class="text-muted small">
                            Upcoming Events
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

<!-- ─── CHARTS ROW ────────────────────── -->
<div class="row g-3 mb-4">

    <!-- Line Chart — Monthly -->
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-graph-up me-2 text-primary"></i>
                    Announcements — Last 6 Months
                </h6>
            </div>
            <div class="card-body">
                <canvas id="monthlyChart" height="100"></canvas>
            </div>
        </div>
    </div>

    <!-- Pie Chart — By Category -->
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-pie-chart me-2 text-primary"></i>
                    By Category
                </h6>
            </div>
            <div class="card-body">
                <canvas id="categoryChart" height="200"></canvas>
            </div>
        </div>
    </div>

</div>

@{
    bool isStudentFeed = roleName == "Student";
}

@if (isStudentFeed)
{
    <!-- ─── STUDENT SEARCH BAR ─────────────── -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2">
            <form method="get" class="d-flex gap-2 flex-wrap align-items-center">
                <input type="text"
                       name="searchQuery"
                       value="@Model.SearchQuery"
                       class="form-control form-control-sm"
                       placeholder="Search announcements..."
                       style="width: 220px;" />
                <select name="filterFeedType"
                        class="form-select form-select-sm"
                        style="width: 150px;">
                    <option value="">All Feeds</option>
                    <option value="Academic"
                            selected="@(Model.FilterFeedType == "Academic")">
                        Academic
                    </option>
                    <option value="NonAcademic"
                            selected="@(Model.FilterFeedType == "NonAcademic")">
                        Non-Academic
                    </option>
                </select>
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-search"></i> Search
                </button>
                @if (!string.IsNullOrEmpty(Model.SearchQuery) ||
                     !string.IsNullOrEmpty(Model.FilterFeedType))
                {
                    <a href="/" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-x"></i> Clear
                    </a>
                }
            </form>
        </div>
    </div>

    <!-- ─── SECTION 1: YOUR DEPARTMENT ───── -->
    @if (Model.DepartmentAnnouncements.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-0 pt-3 pb-2">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-pin-angle-fill me-2 text-primary"></i>
                    Your Department
                    <span class="text-muted fw-normal small ms-1">— guaranteed for you</span>
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    @await Html.PartialAsync("_AnnouncementRows", Model.DepartmentAnnouncements)
                </div>
            </div>
        </div>
    }

    <!-- ─── SECTION 2: FOR YOU ────────────── -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white border-0 pt-3 pb-2">
            <h6 class="fw-bold mb-0">
                <i class="bi bi-stars me-2 text-warning"></i>
                For You
                <span class="text-muted fw-normal small ms-1">— based on what you read</span>
            </h6>
        </div>
        <div class="card-body p-0">
            @if (Model.ForYouAnnouncements.Count == 0)
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-binoculars fs-2 d-block mb-2"></i>
                    No personalized picks yet — browse more announcements to train your feed
                </div>
            }
            else
            {
                <div class="table-responsive">
                    @await Html.PartialAsync("_AnnouncementRows", Model.ForYouAnnouncements)
                </div>
            }
        </div>
    </div>

    <!-- ─── SECTION 3: EXPLORE ────────────── -->
    @if (Model.ExploreAnnouncements.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-0 pt-3 pb-2">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-compass me-2 text-success"></i>
                    Explore
                    <span class="text-muted fw-normal small ms-1">— from other departments</span>
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    @await Html.PartialAsync("_AnnouncementRows", Model.ExploreAnnouncements)
                </div>
            </div>
        </div>
    }
}
else
{
    <!-- ─── SEARCH + TABLE (non-student roles) ─── -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3">
            <div class="d-flex justify-content-between
                        align-items-center flex-wrap gap-2">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-table me-2 text-primary"></i>
                    Recent Announcements
                </h6>

                <form method="get" class="d-flex gap-2 flex-wrap">
                    <input type="text"
                           name="searchQuery"
                           value="@Model.SearchQuery"
                           class="form-control form-control-sm"
                           placeholder="Search announcements..."
                           style="width: 200px;" />

                    <select name="filterFeedType"
                            class="form-select form-select-sm"
                            style="width: 140px;">
                        <option value="">All Feeds</option>
                        <option value="Academic"
                                selected="@(Model.FilterFeedType == "Academic")">
                            Academic
                        </option>
                        <option value="NonAcademic"
                                selected="@(Model.FilterFeedType == "NonAcademic")">
                            Non-Academic
                        </option>
                    </select>

                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-search"></i>
                        Search
                    </button>

                    @if (!string.IsNullOrEmpty(Model.SearchQuery) ||
                         !string.IsNullOrEmpty(Model.FilterFeedType))
                    {
                        <a href="/" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-x"></i>
                            Clear
                        </a>
                    }
                </form>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Title</th>
                            <th>Category</th>
                            <th>Feed</th>
                            <th>Tags</th>
                            <th>Author</th>
                            <th>Views</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentAnnouncements.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    No announcements found
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.RecentAnnouncements)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <a href="/Announcement/Details/@item.AnnouncementID"
                                           class="text-decoration-none fw-semibold text-dark">
                                            @item.Title
                                        </a>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill"
                                              style="background-color: @item.CategoryColor">
                                            @item.CategoryName
                                        </span>
                                    </td>
                                    <td>
                                        @if (item.FeedType == "Academic")
                                        {
                                            <span class="badge bg-primary">
                                                <i class="bi bi-mortarboard me-1"></i>Academic
                                            </span>
                                        }
                                        else if (item.FeedType == "Emergency")
                                        {
                                            <span class="badge bg-danger">
                                                <i class="bi bi-exclamation-triangle me-1"></i>Emergency
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-building me-1"></i>Non-Academic
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @foreach (var tag in item.Tags.Take(2))
                                        {
                                            <span class="badge bg-light text-dark border me-1">@tag</span>
                                        }
                                        @if (item.Tags.Count > 2)
                                        {
                                            <span class="badge bg-light text-muted border">
                                                +@(item.Tags.Count - 2)
                                            </span>
                                        }
                                    </td>
                                    <td class="text-muted small">@item.AuthorName</td>
                                    <td class="text-muted small">
                                        <i class="bi bi-eye me-1"></i>@item.ViewCount
                                    </td>
                                    <td class="text-muted small">
                                        @(item.PublishedAt.HasValue
                                            ? item.PublishedAt.Value.ToString("MMM dd, yyyy")
                                            : "—")
                                    </td>
                                    <td>
                                        @if (item.Status == "Published")
                                        {
                                            <span class="badge bg-success">Published</span>
                                        }
                                        else if (item.Status == "Draft")
                                        {
                                            <span class="badge bg-warning text-dark">Draft</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@item.Status</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section Scripts {
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // ─── Monthly Line Chart ───────────────
        const monthlyCtx = document
            .getElementById('monthlyChart')
            .getContext('2d');

        new Chart(monthlyCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(
                                    System.Text.Json.JsonSerializer
                                            .Serialize(Model.MonthLabels)),
            datasets: [{
                label: 'Announcements',
                data: @Html.Raw(
                                        System.Text.Json.JsonSerializer
                                                .Serialize(Model.MonthlyCount)),
                borderColor: '#0d6efd',
                backgroundColor: 'rgba(13,110,253,0.1)',
                borderWidth: 2,
                fill: true,
                tension: 0.4,
                pointBackgroundColor: '#0d6efd',
                pointRadius: 5
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { stepSize: 1 }
                }
            }
        }
    });

        // ─── Category Pie Chart ───────────────
        const categoryCtx = document
            .getElementById('categoryChart')
            .getContext('2d');

        new Chart(categoryCtx, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(
                                System.Text.Json.JsonSerializer
                                        .Serialize(Model.CategoryLabels)),
            datasets: [{
                data: @Html.Raw(
                                        System.Text.Json.JsonSerializer
                                                .Serialize(Model.CategoryCount)),
                backgroundColor: [
                    '#0d6efd', '#198754', '#dc3545',
                    '#ffc107', '#0dcaf0', '#6f42c1',
                    '#fd7e14'
                ],
                borderWidth: 2,
                borderColor: '#fff'
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { font: { size: 11 } }
                }
            }
        }
    });
</script>
}