@model EduConnect.Web.ViewModels.EventRegistrantsViewModel
@{
    ViewData["Title"] = "Registrants — " + Model.EventTitle;
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex align-items-start
                justify-content-between mb-4 gap-3">
        <div>
            <a href="/Event/Details/@Model.EventID"
               class="btn btn-outline-secondary btn-sm mb-2">
                <i class="bi bi-arrow-left me-1"></i>
                Back to Event
            </a>
            <h4 class="fw-bold mb-1">@Model.EventTitle</h4>
            <div class="text-muted small">
                <i class="bi bi-calendar3 me-1"></i>
                @Model.StartDateTime.ToString("MMMM dd, yyyy · h:mm tt")
                @if (!string.IsNullOrEmpty(Model.Location))
                {
                    <span class="ms-2">
                        <i class="bi bi-geo-alt me-1"></i>@Model.Location
                    </span>
                }
            </div>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="card-body p-2">
                    <div class="fs-2 fw-bold text-primary">
                        @Model.RegisteredCount
                    </div>
                    <div class="small text-muted">Registered</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="card-body p-2">
                    <div class="fs-2 fw-bold text-success">
                        @Model.AttendedCount
                    </div>
                    <div class="small text-muted">Attended</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="card-body p-2">
                    <div class="fs-2 fw-bold text-secondary">
                        @Model.CancelledCount
                    </div>
                    <div class="small text-muted">Cancelled</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="card-body p-2">
                    <div class="fs-2 fw-bold text-warning">
                        @Model.WaitlistedCount
                    </div>
                    <div class="small text-muted">Waitlisted</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Registrations Table -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0 pt-3
                    d-flex align-items-center">
            <h6 class="fw-bold mb-0">
                <i class="bi bi-people me-2 text-primary"></i>
                Registrants
                <span class="badge bg-primary ms-1">
                    @Model.Registrations.Count
                </span>
            </h6>
        </div>
        <div class="card-body p-0">
            @if (Model.Registrations.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">#</th>
                                <th>Student</th>
                                <th>Student ID</th>
                                <th>Department</th>
                                <th>Status</th>
                                <th>Registered On</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rowNum = 1; }
                            @foreach (var reg in Model.Registrations)
                            {
                                <tr>
                                    <td class="ps-3 text-muted small">
                                        @rowNum++
                                    </td>
                                    <td>
                                        <div class="fw-semibold small">
                                            @reg.StudentName
                                        </div>
                                        <div class="text-muted"
                                             style="font-size:11px;">
                                            @reg.Email
                                        </div>
                                    </td>
                                    <td class="small text-muted">
                                        @reg.StudentID
                                    </td>
                                    <td>
                                        <span class="badge bg-light
                                                     text-dark border">
                                            @reg.Department
                                        </span>
                                    </td>
                                    <td>
                                        @if (reg.Status == "Attended")
                                        {
                                            <span class="badge bg-success">
                                                Attended
                                            </span>
                                        }
                                        else if (reg.Status == "Cancelled")
                                        {
                                            <span class="badge bg-secondary">
                                                Cancelled
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary">
                                                Registered
                                            </span>
                                        }
                                    </td>
                                    <td class="small text-muted">
                                        @reg.RegisteredAt.ToString("MMM dd, yyyy")
                                    </td>
                                    <td>
                                        @if (reg.Status == "Registered")
                                        {
                                            <form asp-action="MarkAttendance"
                                                  method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden"
                                                       name="registrationID"
                                                       value="@reg.RegistrationID" />
                                                <input type="hidden"
                                                       name="eventID"
                                                       value="@Model.EventID" />
                                                <button type="submit"
                                                        class="btn btn-success btn-sm">
                                                    <i class="bi bi-check me-1"></i>
                                                    Mark Present
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-people display-4 d-block mb-2"></i>
                    No registrations yet.
                </div>
            }
        </div>
    </div>

    <!-- Waitlist Table -->
    @if (Model.Waitlist.Any())
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 pt-3
                        d-flex align-items-center">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-hourglass-split
                               me-2 text-warning"></i>
                    Waitlist
                    <span class="badge bg-warning
                                 text-dark ms-1">
                        @Model.WaitlistedCount
                    </span>
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Position</th>
                                <th>Student</th>
                                <th>Student ID</th>
                                <th>Department</th>
                                <th>Status</th>
                                <th>Joined On</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in Model.Waitlist)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <span class="badge bg-secondary">
                                            #@entry.Position
                                        </span>
                                    </td>
                                    <td>
                                        <div class="fw-semibold small">
                                            @entry.StudentName
                                        </div>
                                        <div class="text-muted"
                                             style="font-size:11px;">
                                            @entry.Email
                                        </div>
                                    </td>
                                    <td class="small text-muted">
                                        @entry.StudentID
                                    </td>
                                    <td>
                                        <span class="badge bg-light
                                                     text-dark border">
                                            @entry.Department
                                        </span>
                                    </td>
                                    <td>
                                        @if (entry.Status == "Notified")
                                        {
                                            <span class="badge bg-info
                                                         text-dark">
                                                Notified
                                            </span>
                                        }
                                        else if (entry.Status == "Expired")
                                        {
                                            <span class="badge bg-secondary">
                                                Expired
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning
                                                         text-dark">
                                                Waiting
                                            </span>
                                        }
                                    </td>
                                    <td class="small text-muted">
                                        @entry.JoinedAt.ToString("MMM dd, yyyy")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

</div>
