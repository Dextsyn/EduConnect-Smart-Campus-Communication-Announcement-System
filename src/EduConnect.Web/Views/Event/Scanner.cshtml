@{
    ViewData["Title"] = "QR Check-In Scanner";
    var events = ViewBag.Events as IEnumerable<dynamic>;
}

<div class="container py-4">
    <div class="d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-qr-code-scan fs-4 text-primary"></i>
        <h4 class="mb-0">QR Check-In Scanner</h4>
    </div>

    <!-- Event filter -->
    <div class="mb-3">
        <label class="form-label fw-semibold text-muted small text-uppercase">
            Filter by Event (optional)
        </label>
        <select id="eventFilter" class="form-select" style="max-width:420px;">
            <option value="">— All upcoming events —</option>
            @if (events != null)
            {
                foreach (var ev in events)
                {
                    <option value="@ev.EventID">[@ev.Date] @ev.EventTitle</option>
                }
            }
        </select>
    </div>

    <div class="row g-4">
        <!-- Camera column -->
        <div class="col-12 col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3">
                    <div id="reader" style="width:100%;"></div>
                    <div class="d-flex gap-2 mt-3">
                        <button id="btnStart" class="btn btn-primary w-100">
                            <i class="bi bi-camera me-2"></i>Start Scanner
                        </button>
                        <button id="btnStop" class="btn btn-outline-secondary w-100 d-none">
                            <i class="bi bi-stop-circle me-2"></i>Stop
                        </button>
                    </div>
                    <p class="text-muted small text-center mt-2 mb-0">
                        Allow camera access when prompted. Hold a student QR code up to the camera.
                    </p>
                </div>
            </div>

            <!-- Manual lookup -->
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body p-3">
                    <label class="form-label fw-semibold text-muted small text-uppercase">
                        Manual Lookup
                    </label>
                    <div class="input-group">
                        <input type="number" id="manualID" class="form-control"
                               placeholder="Registration ID" min="1" />
                        <button id="btnLookup" class="btn btn-outline-primary">
                            <i class="bi bi-search"></i> Look Up
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Result panel -->
        <div class="col-12 col-lg-7">
            <div id="resultPanel" class="card border-0 shadow-sm d-none">
                <div class="card-body p-4">

                    <!-- Status banner -->
                    <div id="statusBanner" class="alert mb-3 d-flex align-items-center gap-2">
                        <i id="statusIcon" class="bi fs-5"></i>
                        <span id="statusText" class="fw-semibold"></span>
                    </div>

                    <!-- Student info -->
                    <div class="mb-3">
                        <p class="text-muted small text-uppercase fw-semibold mb-1">Student</p>
                        <p class="fw-bold fs-5 mb-0" id="studentName"></p>
                        <p class="text-muted mb-0">
                            <span id="studentID"></span>
                            &nbsp;·&nbsp;
                            <span id="studentDept"></span>
                        </p>
                        <p class="text-muted small mb-0" id="studentEmail"></p>
                    </div>

                    <hr class="my-2">

                    <!-- Event info -->
                    <div class="mb-3">
                        <p class="text-muted small text-uppercase fw-semibold mb-1">Event</p>
                        <p class="fw-semibold mb-0" id="eventTitle"></p>
                        <p class="text-muted small mb-0">
                            <i class="bi bi-calendar3 me-1"></i><span id="eventDate"></span>
                            &nbsp;·&nbsp;
                            <i class="bi bi-geo-alt me-1"></i><span id="eventLocation"></span>
                        </p>
                        <p class="text-muted small mb-0">
                            Registered: <span id="registeredAt"></span>
                        </p>
                    </div>

                    <!-- Mark attended -->
                    <form id="attendForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="hiddenRegID" name="registrationID" value="" />
                        <button type="submit" id="btnAttend"
                                class="btn btn-success w-100 d-none">
                            <i class="bi bi-check2-circle me-2"></i>Mark as Attended
                        </button>
                    </form>

                    <p id="alreadyNote" class="text-success text-center small mt-2 d-none">
                        <i class="bi bi-check-circle me-1"></i>Attendance already recorded.
                    </p>
                </div>
            </div>

            <div id="emptyState" class="text-center text-muted py-5">
                <i class="bi bi-qr-code display-4 opacity-25"></i>
                <p class="mt-3">Scan a QR code or use manual lookup to see student details here.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<script>
    let scanner = null;
    let scanning = false;
    let cooldown = false;

    const btnStart  = document.getElementById('btnStart');
    const btnStop   = document.getElementById('btnStop');
    const btnLookup = document.getElementById('btnLookup');
    const btnAttend = document.getElementById('btnAttend');
    const attendForm = document.getElementById('attendForm');

    btnStart.addEventListener('click', startScanner);
    btnStop.addEventListener('click', stopScanner);
    btnLookup.addEventListener('click', () => {
        const val = document.getElementById('manualID').value.trim();
        if (val) loadScanInfo(parseInt(val));
    });
    document.getElementById('manualID').addEventListener('keydown', e => {
        if (e.key === 'Enter') btnLookup.click();
    });

    attendForm.addEventListener('submit', async e => {
        e.preventDefault();
        const regID = document.getElementById('hiddenRegID').value;
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        btnAttend.disabled = true;
        btnAttend.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Marking...';

        const fd = new FormData();
        fd.append('registrationID', regID);
        fd.append('__RequestVerificationToken', token);

        const res = await fetch('/Event/MarkAttendanceAjax', { method: 'POST', body: fd });
        const data = await res.json();

        if (data.success) {
            setStatus('attended');
            btnAttend.classList.add('d-none');
            document.getElementById('alreadyNote').classList.remove('d-none');
        } else {
            btnAttend.disabled = false;
            btnAttend.innerHTML = '<i class="bi bi-check2-circle me-2"></i>Mark as Attended';
            alert('Failed to mark attendance. Please try again.');
        }
    });

    function startScanner() {
        scanner = new Html5QrcodeScanner('reader', {
            fps: 10,
            qrbox: { width: 250, height: 250 },
            rememberLastUsedCamera: true
        }, false);

        scanner.render(onScanSuccess, onScanError);
        scanning = true;
        btnStart.classList.add('d-none');
        btnStop.classList.remove('d-none');
    }

    function stopScanner() {
        if (scanner) {
            scanner.clear().catch(() => {});
            scanner = null;
        }
        scanning = false;
        btnStart.classList.remove('d-none');
        btnStop.classList.add('d-none');
    }

    function onScanSuccess(decodedText) {
        if (cooldown) return;
        cooldown = true;

        // Extract registrationID from URL like /Event/Scan/42
        const match = decodedText.match(/\/Event\/Scan\/(\d+)/i);
        if (!match) {
            setTimeout(() => { cooldown = false; }, 2000);
            return;
        }

        const regID = parseInt(match[1]);

        // Filter by event if selected
        const eventFilter = document.getElementById('eventFilter').value;

        loadScanInfo(regID, eventFilter).then(() => {
            setTimeout(() => { cooldown = false; }, 2500);
        });
    }

    function onScanError() { /* suppress continuous frame errors */ }

    async function loadScanInfo(regID, filterEventID) {
        const res = await fetch('/Event/ScanInfo/' + regID);
        const data = await res.json();

        if (data.error) {
            showError(data.error);
            return;
        }

        // Optional event filter
        if (filterEventID && data.eventID != filterEventID) {
            showError('wrong_event');
            return;
        }

        document.getElementById('resultPanel').classList.remove('d-none');
        document.getElementById('emptyState').classList.add('d-none');
        document.getElementById('hiddenRegID').value = data.registrationID;

        document.getElementById('studentName').textContent  = data.studentFullName;
        document.getElementById('studentID').textContent    = data.studentID;
        document.getElementById('studentDept').textContent  = data.department;
        document.getElementById('studentEmail').textContent = data.email;
        document.getElementById('eventTitle').textContent   = data.eventTitle;
        document.getElementById('eventDate').textContent    = data.startDateTime;
        document.getElementById('eventLocation').textContent = data.location;
        document.getElementById('registeredAt').textContent  = data.registeredAt;

        document.getElementById('alreadyNote').classList.add('d-none');
        btnAttend.disabled = false;
        btnAttend.innerHTML = '<i class="bi bi-check2-circle me-2"></i>Mark as Attended';

        setStatus(data.status.toLowerCase());
    }

    function setStatus(status) {
        const banner = document.getElementById('statusBanner');
        const icon   = document.getElementById('statusIcon');
        const text   = document.getElementById('statusText');

        banner.className = 'alert mb-3 d-flex align-items-center gap-2';

        if (status === 'registered') {
            banner.classList.add('alert-warning');
            icon.className   = 'bi bi-hourglass-split fs-5';
            text.textContent = 'Not yet checked in';
            btnAttend.classList.remove('d-none');
        } else if (status === 'attended') {
            banner.classList.add('alert-success');
            icon.className   = 'bi bi-check-circle-fill fs-5';
            text.textContent = 'Already checked in';
            btnAttend.classList.add('d-none');
            document.getElementById('alreadyNote').classList.remove('d-none');
        } else if (status === 'cancelled') {
            banner.classList.add('alert-danger');
            icon.className   = 'bi bi-x-circle-fill fs-5';
            text.textContent = 'Registration cancelled';
            btnAttend.classList.add('d-none');
        }
    }

    function showError(code) {
        document.getElementById('resultPanel').classList.add('d-none');
        document.getElementById('emptyState').classList.remove('d-none');

        const msgs = {
            not_found:    'Registration not found. The QR code may be invalid.',
            unauthorized: 'You must be logged in to use the scanner.',
            forbidden:    'You do not have permission to scan QR codes.',
            wrong_event:  'This QR code belongs to a different event.'
        };
        const emptyState = document.getElementById('emptyState');
        emptyState.innerHTML = `
            <i class="bi bi-exclamation-triangle display-4 text-warning opacity-75"></i>
            <p class="mt-3 text-warning fw-semibold">${msgs[code] || 'Unknown error. Try again.'}</p>`;
        setTimeout(() => {
            emptyState.innerHTML = `
                <i class="bi bi-qr-code display-4 opacity-25"></i>
                <p class="mt-3">Scan a QR code or use manual lookup to see student details here.</p>`;
        }, 3000);
    }
</script>
}
