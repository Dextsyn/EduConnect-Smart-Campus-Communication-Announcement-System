@model EduConnect.Web.ViewModels.AnnouncementFormViewModel
@{
    ViewData["Title"] = "Create Announcement";
    var roleName = Context.Session.GetString("RoleName");
}

<!-- ─── PAGE HEADER ──────────────────── -->
<div class="d-flex justify-content-between 
            align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-plus-circle me-2 text-primary"></i>
            Create Announcement
        </h4>
        <small class="text-muted">
            Fill in the details below
        </small>
    </div>
    <a href="/Announcement"
       class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-2"></i>
        Back
    </a>
</div>

<form asp-action="Create"
      method="post"
      enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="row g-4">

        <!-- ─── MAIN FORM ──────────────── -->
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">

                    <!-- Validation Summary -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mb-4">
                            <i class="bi bi-exclamation-circle me-2"></i>
                            Please fix the errors below.
                        </div>
                    }

                    <!-- Title -->
                    <div class="mb-4">
                        <label asp-for="Title"
                               class="form-label fw-semibold">
                            Title <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title"
                               class="form-control form-control-lg"
                               placeholder="Enter announcement title..." />
                        <span asp-validation-for="Title"
                              class="text-danger small"></span>
                    </div>

                    <!-- Body -->
                    <div class="mb-4">
                        <label asp-for="Body"
                               class="form-label fw-semibold">
                            Message <span class="text-danger">*</span>
                        </label>
                        <textarea asp-for="Body"
                                  class="form-control"
                                  rows="8"
                                  placeholder="Write your announcement here...">
                        </textarea>
                        <span asp-validation-for="Body"
                              class="text-danger small"></span>
                    </div>

                    <!-- Photo Upload -->
                    <div class="mb-4">
                        <label asp-for="Photo"
                               class="form-label fw-semibold">
                            Photo
                            <span class="text-muted fw-normal">
                                (optional)
                            </span>
                        </label>
                        <input asp-for="Photo"
                               type="file"
                               class="form-control"
                               accept="image/*"
                               onchange="previewPhoto(this)" />
                        <div class="form-text">
                            Accepted: JPG, PNG, GIF (max 5MB)
                        </div>
                        <div id="photoPreview" class="mt-3 d-none">
                            <img id="previewImg"
                                 class="img-fluid rounded"
                                 style="max-height: 300px;"
                                 alt="Preview" />
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- ─── SETTINGS SIDEBAR ──────── -->
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0">
                        <i class="bi bi-gear me-2 text-primary"></i>
                        Settings
                    </h6>
                </div>
                <div class="card-body">

                    <!-- Category -->
                    <div class="mb-3">
                        <label asp-for="CategoryID"
                               class="form-label fw-semibold">
                            Category <span class="text-danger">*</span>
                        </label>
                        <select asp-for="CategoryID"
                                class="form-select">
                            <option value="">
                                — Select category —
                            </option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.CategoryID">
                                    @cat.CategoryName
                                </option>
                            }
                        </select>
                        <span asp-validation-for="CategoryID"
                              class="text-danger small"></span>
                    </div>

                    <!-- Feed Type -->
                    <div class="mb-3">
                        <label asp-for="FeedType"
                               class="form-label fw-semibold">
                            Feed Type <span class="text-danger">*</span>
                        </label>
                        <!-- ✅ Correct -->
                        @if (roleName != "Administrator")
                            {
                                <select asp-for="FeedType"
                                        class="form-select"
                                        disabled>
                                    <option value="Academic">Academic</option>
                                    <option value="NonAcademic">Non-Academic</option>
                                </select>
                            }
                            else
                            {
                                <select asp-for="FeedType"
                                        class="form-select">
                                    <option value="Academic">Academic</option>
                                    <option value="NonAcademic">Non-Academic</option>
                                    <option value="Emergency">Emergency</option>
                                </select>
                            }
                    </div>

                    <!-- Priority -->
                    <div class="mb-3">
                        <label asp-for="Priority"
                               class="form-label fw-semibold">
                            Priority
                        </label>
                        <select asp-for="Priority"
                                class="form-select">
                            <option value="1">Low</option>
                            <option value="2">Normal</option>
                            <option value="3">High</option>
                            <option value="4">Urgent</option>
                            @if (roleName == "Administrator")
                            {
                                <option value="5">Emergency</option>
                            }
                        </select>
                    </div>

                    <!-- Expiry Date -->
                    <div class="mb-3">
                        <label asp-for="ExpiresAt"
                               class="form-label fw-semibold">
                            Expiry Date
                            <span class="text-muted fw-normal">
                                (optional)
                            </span>
                        </label>
                        <input asp-for="ExpiresAt"
                               type="datetime-local"
                               class="form-control" />
                    </div>

                    <!-- Emergency Toggle (Admin only) -->
                    @if (roleName == "Administrator")
                    {
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input asp-for="IsEmergency"
                                       class="form-check-input"
                                       type="checkbox"
                                       role="switch" />
                                <label asp-for="IsEmergency"
                                       class="form-check-label fw-semibold text-danger">
                                    Mark as Emergency
                                </label>
                            </div>
                        </div>
                    }

                </div>
            </div>

            <!-- Department Tags -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0">
                        <i class="bi bi-tags me-2 text-primary"></i>
                        Target Departments
                    </h6>
                    <small class="text-muted">
                        Select who can see this
                    </small>
                </div>
                <div class="card-body"
                     style="max-height: 300px; overflow-y: auto;">
                    @foreach (var tag in Model.AvailableTags)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="SelectedTagIDs"
                                   value="@tag.TagID"
                                   id="tag_@tag.TagID" />
                            <label class="form-check-label"
                                   for="tag_@tag.TagID">
                                <span class="badge me-1"
                                      style="background-color: @tag.ColorHex">
                                    @tag.ShortName
                                </span>
                                @tag.TagName
                            </label>
                        </div>
                    }
                </div>
            </div>

            <!-- Submit Button -->
            <div class="d-grid gap-2">
                <button type="submit"
                        class="btn btn-primary btn-lg">
                    <i class="bi bi-send me-2"></i>
                    @(ViewBag.IsFaculty == true ? "Save Draft" : "Publish Announcement")
                </button>
                <a href="/Announcement"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    <script>
        function previewPhoto(input) {
            const preview = document
                .getElementById('photoPreview');
            const img = document
                .getElementById('previewImg');

            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    img.src = e.target.result;
                    preview.classList.remove('d-none');
                };
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.classList.add('d-none');
            }
        }
    </script>
}