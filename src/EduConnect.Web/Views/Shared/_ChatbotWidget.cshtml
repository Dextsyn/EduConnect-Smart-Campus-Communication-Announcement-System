<!-- ── EduConnect AI Chatbot Widget ── -->
<style>
    #chatbot-toggle {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 1050;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        box-shadow: 0 4px 16px rgba(0,0,0,.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        border: none;
        cursor: pointer;
    }

    #chatbot-panel {
        position: fixed;
        bottom: 88px;
        right: 24px;
        z-index: 1049;
        width: 360px;
        height: 500px;
        display: none;
        flex-direction: column;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0,0,0,.2);
        overflow: hidden;
        background: #fff;
    }

    #chatbot-panel.open {
        display: flex;
    }

    #chatbot-messages {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: #f8f9fa;
    }

    .chat-bubble {
        max-width: 82%;
        padding: 10px 14px;
        border-radius: 16px;
        font-size: 0.875rem;
        line-height: 1.45;
        word-wrap: break-word;
    }

    .chat-bubble.user {
        align-self: flex-end;
        background: #0d6efd;
        color: #fff;
        border-bottom-right-radius: 4px;
    }

    .chat-bubble.bot {
        align-self: flex-start;
        background: #fff;
        color: #212529;
        border: 1px solid #dee2e6;
        border-bottom-left-radius: 4px;
    }

    .chat-bubble.bot a.chatbot-link {
        color: #0d6efd;
        text-decoration: underline;
        font-weight: 500;
    }

    .chat-bubble.bot a.chatbot-link:hover {
        color: #0a58ca;
    }

    .chat-timestamp {
        font-size: 0.7rem;
        color: #adb5bd;
        margin-top: 2px;
    }

    .chat-timestamp.user { text-align: right; }

    #chatbot-typing {
        display: none;
        align-self: flex-start;
    }

    .typing-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #adb5bd;
        margin: 0 2px;
        animation: typingBounce 1.2s infinite;
    }

    .typing-dot:nth-child(2) { animation-delay: .2s; }
    .typing-dot:nth-child(3) { animation-delay: .4s; }

    @@keyframes typingBounce {
        0%, 60%, 100% { transform: translateY(0); }
        30%            { transform: translateY(-8px); }
    }

    #chatbot-footer {
        display: flex;
        padding: 10px 12px;
        border-top: 1px solid #dee2e6;
        background: #fff;
        gap: 8px;
        align-items: flex-end;
    }

    #chatbot-input {
        flex: 1;
        border: 1px solid #dee2e6;
        border-radius: 20px;
        padding: 8px 14px;
        font-size: 0.875rem;
        resize: none;
        outline: none;
        max-height: 80px;
        overflow-y: auto;
    }

    #chatbot-input:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 3px rgba(13,110,253,.15);
    }

    #chatbot-send {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: none;
        background: #0d6efd;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
    }

    #chatbot-send:disabled {
        background: #adb5bd;
        cursor: not-allowed;
    }
</style>

<!-- Floating toggle button -->
<button id="chatbot-toggle" class="btn btn-primary" title="EduConnect Assistant">
    <i class="bi bi-chat-dots-fill"></i>
</button>

<!-- Chat panel -->
<div id="chatbot-panel">

    <!-- Header -->
    <div class="d-flex align-items-center px-3 py-2 bg-primary text-white">
        <i class="bi bi-robot fs-5 me-2"></i>
        <div class="flex-grow-1">
            <div class="fw-semibold" style="font-size:.9rem;">EduConnect Assistant</div>
            <div style="font-size:.72rem;opacity:.8;">Adamson University</div>
        </div>
        <button id="chatbot-close" class="btn btn-link text-white p-0 ms-2" style="font-size:1.1rem;">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    <!-- Messages -->
    <div id="chatbot-messages">
        <div class="chat-bubble bot">
            Hi! I'm your EduConnect Assistant. I can help you with announcements, upcoming events, and how to use the platform. What would you like to know?
        </div>
    </div>

    <!-- Typing indicator -->
    <div id="chatbot-typing" style="padding: 0 16px 8px 16px;">
        <span class="chat-bubble bot" style="padding: 10px 14px;">
            <span class="typing-dot"></span>
            <span class="typing-dot"></span>
            <span class="typing-dot"></span>
        </span>
    </div>

    <!-- Input footer -->
    <div id="chatbot-footer">
        <textarea id="chatbot-input"
                  rows="1"
                  maxlength="1000"
                  placeholder="Ask about announcements, events…"></textarea>
        <button id="chatbot-send" title="Send">
            <i class="bi bi-send-fill"></i>
        </button>
    </div>
</div>

<script>
(function () {
    const toggle   = document.getElementById('chatbot-toggle');
    const panel    = document.getElementById('chatbot-panel');
    const closeBtn = document.getElementById('chatbot-close');
    const messages = document.getElementById('chatbot-messages');
    const typing   = document.getElementById('chatbot-typing');
    const input    = document.getElementById('chatbot-input');
    const sendBtn  = document.getElementById('chatbot-send');

    let historyLoaded = false;

    function scrollToBottom() {
        messages.scrollTop = messages.scrollHeight;
    }

    function renderBotText(text) {
        const escaped = text
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
        return escaped.replace(
            /\[([^\]]+)\]\((\/(?:Announcement|Event)\/Details\/\d+)\)/g,
            '<a href="$2" class="chatbot-link" target="_blank" rel="noopener noreferrer">$1</a>'
        );
    }

    function appendMessage(role, text, timestamp) {
        const wrapper = document.createElement('div');
        wrapper.style.display = 'flex';
        wrapper.style.flexDirection = 'column';
        wrapper.style.alignItems = role === 'user' ? 'flex-end' : 'flex-start';

        const bubble = document.createElement('div');
        bubble.classList.add('chat-bubble', role);
        if (role === 'bot') {
            bubble.innerHTML = renderBotText(text);
        } else {
            bubble.textContent = text;
        }

        const ts = document.createElement('div');
        ts.classList.add('chat-timestamp', role);
        ts.textContent = timestamp || '';

        wrapper.appendChild(bubble);
        if (timestamp) wrapper.appendChild(ts);
        messages.appendChild(wrapper);
        scrollToBottom();
    }

    function setLoading(loading) {
        sendBtn.disabled = loading;
        input.disabled   = loading;
        typing.style.display = loading ? 'block' : 'none';
        if (loading) scrollToBottom();
    }

    async function loadHistory() {
        if (historyLoaded) return;
        historyLoaded = true;

        try {
            const res  = await fetch('/Chatbot/History');
            const data = await res.json();
            if (Array.isArray(data) && data.length > 0) {
                // Clear the greeting if there's real history
                messages.innerHTML = '';
                data.forEach(m => appendMessage(m.role, m.message, m.timestamp));
            }
        } catch { /* silently ignore — greeting stays */ }
    }

    async function sendMessage() {
        const text = input.value.trim();
        if (!text || sendBtn.disabled) return;

        input.value = '';
        input.style.height = 'auto';
        appendMessage('user', text, new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }));
        setLoading(true);

        try {
            const res  = await fetch('/Chatbot/Send', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text })
            });
            const data = await res.json();
            setLoading(false);

            if (data.response) {
                appendMessage('bot', data.response, new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }));
            } else {
                appendMessage('bot', 'Sorry, I could not process that request. Please try again.', '');
            }
        } catch {
            setLoading(false);
            appendMessage('bot', 'Connection error. Please check your connection and try again.', '');
        }
    }

    toggle.addEventListener('click', () => {
        const isOpen = panel.classList.contains('open');
        if (isOpen) {
            panel.classList.remove('open');
            toggle.innerHTML = '<i class="bi bi-chat-dots-fill"></i>';
        } else {
            panel.classList.add('open');
            toggle.innerHTML = '<i class="bi bi-x-lg"></i>';
            loadHistory();
            setTimeout(() => input.focus(), 100);
        }
    });

    closeBtn.addEventListener('click', () => {
        panel.classList.remove('open');
        toggle.innerHTML = '<i class="bi bi-chat-dots-fill"></i>';
    });

    sendBtn.addEventListener('click', sendMessage);

    input.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    // Auto-resize textarea
    input.addEventListener('input', () => {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 80) + 'px';
    });
})();
</script>
